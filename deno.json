{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "imports": {
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/fs": "jsr:@std/fs@^1"
  },
  "tasks": {
    "dev": "deno run --allow-read --allow-env --allow-net --unstable-cron --watch main.ts",
    "start": "deno run --allow-read --allow-env --allow-net --unstable-cron main.ts",
    "deploy": "deployctl deploy --prod main.ts"
  }
}
